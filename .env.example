# PostgreSQL baglanti bilgileri
DATABASE_URL=postgresql+asyncpg://safetrade_user:supersecretpassword@localhost:5432/safetrade_db

# Uygulama ayarlari
APP_NAME=Eren API
APP_VERSION=1.0.0
DEBUG=false

# ---------------------------------------------------------------------------
# JWT Kimlik Dogrulama Ayarlari
# ---------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Harici API Anahtarlari
# ---------------------------------------------------------------------------

# NewsAPI.org — https://newsapi.org/register adresinden ucretsiz alinabilir
NEWS_API_KEY=your_newsapi_key_here

# Finnhub.io — https://finnhub.io adresinden ucretsiz alinabilir
# Sandbox testi icin: sandbox_c... formatinda bir token kullanilabilir
FINNHUB_API_KEY=your_finnhub_key_here

# ExchangeRate-API — https://www.exchangerate-api.com adresinden ucretsiz alinabilir (1500 istek/ay)
EXCHANGE_RATE_API_KEY=your_exchangerate_key_here

# HTTP istemci zaman asimi (saniye) — opsiyonel, varsayilan degerler asagidaki gibidir
HTTP_TIMEOUT_SECONDS=10.0
HTTP_CONNECT_TIMEOUT_SECONDS=5.0
